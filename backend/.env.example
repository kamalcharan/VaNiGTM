# ═══════════════════════════════════════════════════════
# KI-Prime Backend — Environment Variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────
# PostgreSQL connection string (VPS-hosted, shared VN_ + KI_ tables)
DB_PRIMARY=postgresql://user:password@host:5432/ki_prime_db

# SSL for remote connections (Railway/DO → VPS). Set false for local dev.
DB_PRIMARY_SSL=false

# ── Auth ────────────────────────────────────────────────
# JWT signing secret (min 32 chars in production)
JWT_SECRET=change-me-in-production

# Max concurrent sessions per user (overrides VN_subscriptions.max_sessions)
MAX_SESSIONS=50

# ── Server ──────────────────────────────────────────────
# Express port
PORT=3001

# CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:3000

# Environment: 'development' for console logging, 'production' for vn_error_log
NODE_ENV=development

# ── Frontend ────────────────────────────────────────────
# API URL for frontend to reach backend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Default theme and color mode for ThemeScript SSR
NEXT_PUBLIC_DEFAULT_THEME=vikuna-black
NEXT_PUBLIC_DEFAULT_COLOR_MODE=dark

# ── Feature Flags ───────────────────────────────────────
# Skip real AI/LLM calls (use mock responses)
VANI_MOCK=true

# ── Vikuna Agent Core ───────────────────────────────────
# VPS-hosted LLM (OpenAI-compatible /v1/chat/completions endpoint).
# Works with Ollama, vLLM, llama.cpp server, LM Studio.
LLM_PRIMARY_URL=http://localhost:11434
LLM_PRIMARY_MODEL=qwen2.5
LLM_PRIMARY_TIMEOUT_MS=60000

# Agent worker — separate process that polls gt_events and dispatches agents.
WORKER_POLL_MS=3000
WORKER_BATCH_SIZE=5

# ── Google Drive (ingestion-skill) ──────────────────────
# OAuth credentials for connecting a tenant's Google Drive folder as a
# knowledge source. Create a Web Application client in Google Cloud Console
# and add the redirect URI to the authorized list.
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REDIRECT_URI=http://localhost:3000/api/v1/ingest/connect/gdrive/callback
