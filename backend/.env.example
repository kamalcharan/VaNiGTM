# ═══════════════════════════════════════════════════════
# KI-Prime Backend — Environment Variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────
# PostgreSQL connection string (VPS-hosted, shared VN_ + KI_ tables)
DB_PRIMARY=postgresql://user:password@host:5432/ki_prime_db

# SSL for remote connections (Railway/DO → VPS). Set false for local dev.
DB_PRIMARY_SSL=false

# ── Auth ────────────────────────────────────────────────
# JWT signing secret (min 32 chars in production)
JWT_SECRET=change-me-in-production

# Max concurrent sessions per user (overrides VN_subscriptions.max_sessions)
MAX_SESSIONS=50

# ── Server ──────────────────────────────────────────────
# Express port
PORT=3001

# CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:3000

# Environment: 'development' for console logging, 'production' for vn_error_log
NODE_ENV=development

# ── Frontend ────────────────────────────────────────────
# API URL for frontend to reach backend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Default theme and color mode for ThemeScript SSR
NEXT_PUBLIC_DEFAULT_THEME=vikuna-black
NEXT_PUBLIC_DEFAULT_COLOR_MODE=dark

# ── Feature Flags ───────────────────────────────────────
# Skip real AI/LLM calls (use mock responses)
VANI_MOCK=true
