{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@ki-prime/shared/*": ["./shared/*"],
      "@ki-prime/skills/*": ["./skills/*"]
    }
  },
  "include": [
    "startup.ts",
    "vani.config.ts",
    "tiers.config.ts",
    "shared/**/*.ts",
    "skills/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vani-base"
  ]
}
