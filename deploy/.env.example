# ============================================================
# ProKey — Environment Configuration
#
# Copy this file to .env and fill in your values.
# Run ./configure.sh for guided setup.
#
# NEVER commit .env to version control.
# ============================================================

# ── Instance ─────────────────────────────────────────────────
# Unique name for this deployment (used as Docker container prefix)
# Use lowercase letters, numbers, hyphens only. E.g: prokey-demo, prokey-abc-mfd
INSTANCE_NAME=prokey-demo

# Docker image tag to pull. Use 'latest' or a specific version e.g. '1.2.0'
IMAGE_TAG=latest

# Host port nginx listens on. 80 = standard HTTP. Change if 80 is taken.
APP_PORT=80

# ── Database (Remote VPS) ─────────────────────────────────────
# Full PostgreSQL connection string to your VPS database.
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://ki_user:mypassword@203.0.113.10:5432/ki_prime_db
DB_PRIMARY=postgresql://USERNAME:PASSWORD@YOUR_VPS_IP:5432/ki_prime_db

# Set to true for remote VPS connections (enables SSL with self-signed cert support)
DB_PRIMARY_SSL=true

# ── Auth Secrets ─────────────────────────────────────────────
# Long random strings — minimum 32 characters each.
# Generate with: openssl rand -hex 32
# IMPORTANT: These must match the values used when your tenant data was created.
#            Changing them will invalidate all existing sessions.
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_LONG_RANDOM_STRING_MIN_32_CHARS

# ── App (do not change unless you know what you're doing) ────
NODE_ENV=production
PORT=3001
