{
  "name": "goal-dashboard",
  "title": "Financial Goals",
  "layout": "dashboard-3row",
  "slots": [
    {
      "row": 1,
      "components": [
        { "type": "kpi-card", "data": "goals[0]", "variant": "goal-progress" },
        { "type": "kpi-card", "data": "goals[1]", "variant": "goal-progress" },
        { "type": "kpi-card", "data": "goals[2]", "variant": "goal-progress" }
