{
  "name": "plan-vs-reality",
  "title": "Plan vs Reality",
  "layout": "comparison",
  "slots": [
    {
      "row": 1,
      "components": [
        { "type": "stat-row", "data": "comparison_header", "span": 3, "props": { "variant": "hero" } }
      ]
    },
    {
      "row": 2,
      "components": [
        { "type": "doughnut", "data": "target_allocation", "props": { "centerLabel": "Target" } },
        { "type": "doughnut", "data": "current_allocation", "props": { "centerLabel": "Actual" } },
        { "type": "bar-chart", "data": "drift_analysis", "props": { "horizontal": true } }
      ]
    },
    {
      "row": 3,
      "components": [
        { "type": "data-table", "data": "rebalance_actions", "span": 2, "variant": "detailed" },
        { "type": "suggestion", "data": "rebalance_suggestion" }
      ]
    },
    {
      "row": 4,
      "components": [
        { "type": "action-bar", "data": "rebalance_actions_bar", "span": 3, "props": { "variant": "primary" } }
      ]
    }
  ]
}
